<Window x:Class="MugiSideBrowser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="MugiSideBrowser" Height="800" Width="400"
        WindowStyle="None" ResizeMode="NoResize"
        Background="{DynamicResource AppBackground}" FontFamily="Segoe UI Variable Text">
    <Window.Resources>
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SidebarDockButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="LeftResizeColumn" Width="4"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="RightResizeColumn" Width="0"/>
        </Grid.ColumnDefinitions>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition x:Name="BottomResizeRow" Height="0"/>
        </Grid.RowDefinitions>

        <!-- 左側のリサイズグリップ (右側に配置されている時用) -->
        <Border x:Name="LeftResizeGrip" Grid.Column="0" Grid.Row="0" Background="Transparent" Cursor="SizeWE" 
                MouseLeftButtonDown="ResizeGrip_MouseDown" MouseMove="ResizeGrip_MouseMove" MouseLeftButtonUp="ResizeGrip_MouseUp"/>
        
        <!-- 下側のリサイズグリップ (自由配置モード用) -->
        <Border x:Name="BottomResizeGrip" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Background="Transparent" Cursor="SizeNS" 
                MouseLeftButtonDown="ResizeGrip_MouseDown" MouseMove="ResizeGrip_MouseMove" MouseLeftButtonUp="ResizeGrip_MouseUp"/>

        <!-- メインコンテンツ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" x:Name="TitleBarRow"/>
                <RowDefinition Height="Auto" x:Name="AddressBarRow"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar / Toolbar -->
            <Border Grid.Row="0" Background="{DynamicResource TitleBarBackground}" Padding="8,4" 
                    MouseLeftButtonDown="TitleBar_MouseDown" 
                    MouseMove="TitleBar_MouseMove" 
                    MouseLeftButtonUp="TitleBar_MouseUp">
                <DockPanel>
                    <!-- Left: Navigation (Empty for clean titlebar) -->
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <TextBlock Text="MugiSideBrowser" Foreground="{DynamicResource SecondaryText}" FontSize="12" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </StackPanel>
                    
                    <!-- Right: Window Controls -->
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                        <Button x:Name="MinimizeButton" Content="" Click="Minimize_Click" Style="{StaticResource ToolbarButtonStyle}" ToolTip="最小化"/>
                        <Button Content="" Click="Close_Click" Style="{StaticResource ToolbarButtonStyle}" Foreground="{DynamicResource DangerForeground}" ToolTip="閉じる"/>
                    </StackPanel>

                    <!-- Center: Spacer -->
                    <Grid/>
                </DockPanel>
            </Border>

            <!-- Address Bar & Tools -->
            <Border Grid.Row="1" Background="{DynamicResource AddressBarBackground}" Padding="8,4" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1">
                <DockPanel LastChildFill="True">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" Margin="0,0,4,0">
                        <Button Content="" Click="Back_Click" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,4,0" ToolTip="戻る"/>
                        <Button Content="" Click="Forward_Click" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,4,0" ToolTip="進む"/>
                    </StackPanel>
                    
                    <Button Content="" Style="{StaticResource ToolbarButtonStyle}" 
                            Click="PageTools_Click" ToolTip="ページ操作" DockPanel.Dock="Right" Margin="4,0,0,0">
                        <Button.ContextMenu>
                            <ContextMenu x:Name="PageToolsMenu">
                                <MenuItem Header="ページを更新" Click="Reload_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem x:Name="UserAgentMenuItem" Header="モバイル表示に切替" Click="UserAgent_Click">
                                    <MenuItem.Icon>
                                        <TextBlock x:Name="UserAgentMenuIcon" Text="" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="このページをブックマーク" Click="Star_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="URLをコピー" Click="CopyUrl_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="標準ブラウザで開く" Click="OpenExternal_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    
                    <TextBox x:Name="UrlTextBox" Background="{DynamicResource BorderColor}" Foreground="{DynamicResource PrimaryText}" BorderThickness="1" BorderBrush="{DynamicResource TextBoxBorderColor}"
                              Padding="8,4" VerticalContentAlignment="Center" KeyDown="UrlTextBox_KeyDown"
                              FontSize="13" SelectionBrush="{DynamicResource SelectionBackground}">
                        <TextBox.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                </DockPanel>
            </Border>

            <!-- Main Content Area (Dock + Browser Views Group) -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" x:Name="BookmarkDockColumn"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Vertical Sidebar Dock (Left) -->
                <!-- Vertical Sidebar Dock (Left) -->
                <Border Grid.Column="0" Width="48" Background="{DynamicResource TitleBarBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Top: Add Bookmark Button -->
                            <RowDefinition Height="*"/>    <!-- Center: Bookmarks Scroll List -->
                            <RowDefinition Height="Auto"/> <!-- Bottom: Tools Button -->
                        </Grid.RowDefinitions>

                        <!-- Add Bookmark Button -->
                        <Button Grid.Row="0" Content="" Style="{StaticResource SidebarDockButtonStyle}" 
                                Click="Star_Click" ToolTip="現在のページをブックマーク" Margin="4,6"/>

                        <!-- Bookmark List -->
                        <ScrollViewer Grid.Row="1" x:Name="BookmarkScrollViewer" 
                                      HorizontalScrollBarVisibility="Disabled" 
                                      VerticalScrollBarVisibility="Hidden"
                                      PreviewMouseWheel="BookmarkScrollViewer_PreviewMouseWheel">
                            <ItemsControl x:Name="BookmarkList">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Vertical"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Cursor="Hand" Padding="8" CornerRadius="6" Margin="4,2"
                                                ToolTip="{Binding Title}"
                                                PreviewMouseLeftButtonDown="Bookmark_PreviewMouseLeftButtonDown" 
                                                MouseMove="Bookmark_MouseMove"
                                                MouseLeftButtonUp="Bookmark_MouseLeftButtonUp"
                                                AllowDrop="True" Drop="Bookmark_Drop" DragOver="Bookmark_DragOver">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
                                                        </Trigger>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Border.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="下のウィンドウで開く" Click="OpenInBottomWindow_Click"/>
                                                    <Separator/>
                                                    <MenuItem Header="このページの状態をクリア (メモリ解放)" Click="ClearBookmarkState_Click"/>
                                                    <Separator/>
                                                    <MenuItem Header="削除" Click="DeleteBookmark_Click"/>
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <!-- Favicon Image with Scale Transform on Hover for WOW effect -->
                                            <Grid Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Image Source="{Binding DisplayFaviconUrl}" Width="20" Height="20" IsHitTestVisible="False" RenderOptions.BitmapScalingMode="HighQuality">
                                                    <Image.Style>
                                                        <Style TargetType="Image">
                                                            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                                            <Setter Property="RenderTransform">
                                                                <Setter.Value>
                                                                    <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=IsMouseOver}" Value="True">
                                                                    <DataTrigger.EnterActions>
                                                                        <BeginStoryboard>
                                                                            <Storyboard>
                                                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)" To="1.15" Duration="0:0:0.15"/>
                                                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)" To="1.15" Duration="0:0:0.15"/>
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </DataTrigger.EnterActions>
                                                                    <DataTrigger.ExitActions>
                                                                        <BeginStoryboard>
                                                                            <Storyboard>
                                                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.15"/>
                                                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.15"/>
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </DataTrigger.ExitActions>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Image.Style>
                                                </Image>
                                                <!-- Indicator for memory load status -->
                                                <Ellipse Width="6" Height="6" Fill="#FF4CAF50" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-2,-2" IsHitTestVisible="False">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsLoaded}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Tools / Settings Button at the bottom -->
                        <Button Grid.Row="2" Content="" Style="{StaticResource SidebarDockButtonStyle}" 
                                Click="Tools_Click" ToolTip="ツールメニュー" Margin="4,6">
                            <Button.ContextMenu>
                                <ContextMenu x:Name="ToolsMenu">
                                    <MenuItem x:Name="SplitMenuItem" Header="上下分割を切り替え" Click="SplitView_Click">
                                        <MenuItem.Icon>
                                            <TextBlock Text="" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem x:Name="ExternalBrowserMenuItem" Header="新しいウィンドウを標準ブラウザで開く" IsCheckable="True" IsChecked="True" Click="ExternalBrowser_Click">
                                        <MenuItem.Icon>
                                            <TextBlock Text="" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <Separator/>
                                    <MenuItem Header="表示モード">
                                        <MenuItem.Icon>
                                            <TextBlock Text="" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                        </MenuItem.Icon>
                                        <MenuItem x:Name="AlwaysVisibleMenuItem" Header="常時表示 (AppBar)" Click="DisplayMode_Click" IsChecked="True"/>
                                        <MenuItem x:Name="AutoHideMenuItem" Header="自動的に隠す (Hot Corner)" Click="DisplayMode_Click"/>
                                        <MenuItem x:Name="NormalWindowMenuItem" Header="ウィンドウ (自由配置)" Click="DisplayMode_Click"/>
                                    </MenuItem>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                    </Grid>
                </Border>

                <!-- Main Content Area (Browser Views Group) -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" x:Name="TopRow"/>
                        <RowDefinition Height="Auto" x:Name="SplitterRow"/>
                        <RowDefinition Height="0" x:Name="BottomRow"/>
                    </Grid.RowDefinitions>

                    <Grid x:Name="WebViewContainer" Grid.Row="0" Margin="0"/>

                    <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" Background="{DynamicResource BorderColor}" 
                                  Visibility="Collapsed" x:Name="VerticalSplitter" ShowsPreview="True"/>

                    <Grid x:Name="WebViewBottomContainer" Grid.Row="2" Margin="0" Visibility="Collapsed"/>
                </Grid>
            </Grid>
        </Grid>

        <!-- 右側のリサイズグリップ (左側に配置されている時用) -->
        <Border x:Name="RightResizeGrip" Grid.Column="2" Background="Transparent" Cursor="SizeWE" 
                MouseLeftButtonDown="ResizeGrip_MouseDown" MouseMove="ResizeGrip_MouseMove" MouseLeftButtonUp="ResizeGrip_MouseUp"/>

        <!-- リサイズ中のガイド線 -->
        <Rectangle x:Name="ResizePreview" Grid.Column="1" HorizontalAlignment="Left" Width="2" Fill="{DynamicResource SelectionBackground}" 
                   Visibility="Collapsed" IsHitTestVisible="False" Opacity="0.8"/>
    </Grid>

</Window>
