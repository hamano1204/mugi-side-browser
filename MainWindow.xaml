<Window x:Class="MugiSideBrowser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="MugiSideBrowser" Height="800" Width="400"
        WindowStyle="None" ResizeMode="NoResize"
        Background="#1E1E1E" FontFamily="Segoe UI Variable Text">
    <Window.Resources>
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3D3D3D"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BookmarkButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Margin" Value="0,0,2,0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="LeftResizeColumn" Width="4"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="RightResizeColumn" Width="0"/>
        </Grid.ColumnDefinitions>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition x:Name="BottomResizeRow" Height="0"/>
        </Grid.RowDefinitions>

        <!-- 左側のリサイズグリップ (右側に配置されている時用) -->
        <Border x:Name="LeftResizeGrip" Grid.Column="0" Grid.Row="0" Background="Transparent" Cursor="SizeWE" 
                MouseLeftButtonDown="ResizeGrip_MouseDown" MouseMove="ResizeGrip_MouseMove" MouseLeftButtonUp="ResizeGrip_MouseUp"/>
        
        <!-- 下側のリサイズグリップ (自由配置モード用) -->
        <Border x:Name="BottomResizeGrip" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Background="Transparent" Cursor="SizeNS" 
                MouseLeftButtonDown="ResizeGrip_MouseDown" MouseMove="ResizeGrip_MouseMove" MouseLeftButtonUp="ResizeGrip_MouseUp"/>

        <!-- メインコンテンツ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" x:Name="TitleBarRow"/>
                <RowDefinition Height="Auto" x:Name="AddressBarRow"/>
                <RowDefinition Height="Auto" x:Name="BookmarkBarRow"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar / Toolbar -->
            <Border Grid.Row="0" Background="#2D2D2D" Padding="8,4" 
                    MouseLeftButtonDown="TitleBar_MouseDown" 
                    MouseMove="TitleBar_MouseMove" 
                    MouseLeftButtonUp="TitleBar_MouseUp">
                <DockPanel>
                    <!-- Left: Navigation -->
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <Button Content="" Style="{StaticResource ToolbarButtonStyle}" 
                                Click="Tools_Click" ToolTip="ツールメニュー" Margin="0,0,4,0">
                            <Button.ContextMenu>
                                <ContextMenu x:Name="ToolsMenu">
                                    <MenuItem x:Name="SplitMenuItem" Header="上下分割を切り替え" Click="SplitView_Click">
                                        <MenuItem.Icon>
                                            <TextBlock Text="" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem x:Name="UserAgentMenuItem" Header="デスクトップ表示に切替" Click="UserAgent_Click">
                                        <MenuItem.Icon>
                                            <TextBlock x:Name="UserAgentMenuIcon" Text="" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem x:Name="ExternalBrowserMenuItem" Header="新しいウィンドウを標準ブラウザで開く" IsCheckable="True" IsChecked="True" Click="ExternalBrowser_Click">
                                        <MenuItem.Icon>
                                            <TextBlock Text="" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="ページを更新" Click="Reload_Click">
                                        <MenuItem.Icon>
                                            <TextBlock Text="" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="メモ" Click="Memo_Click">
                                        <MenuItem.Icon>
                                            <TextBlock Text="" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <Separator/>
                                    <MenuItem Header="表示モード">
                                        <MenuItem.Icon>
                                            <TextBlock Text="" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                        </MenuItem.Icon>
                                        <MenuItem x:Name="AlwaysVisibleMenuItem" Header="常時表示 (AppBar)" Click="DisplayMode_Click" IsChecked="True"/>
                                        <MenuItem x:Name="AutoHideMenuItem" Header="自動的に隠す (Hot Corner)" Click="DisplayMode_Click"/>
                                        <MenuItem x:Name="NormalWindowMenuItem" Header="ウィンドウ (自由配置)" Click="DisplayMode_Click"/>
                                    </MenuItem>
                                    <Separator/>
                                    <MenuItem Header="このページをブックマーク" Click="Star_Click">
                                        <MenuItem.Icon>
                                            <TextBlock Text="" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="URLをコピー" Click="CopyUrl_Click">
                                        <MenuItem.Icon>
                                            <TextBlock Text="" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="標準ブラウザで開く" Click="OpenExternal_Click">
                                        <MenuItem.Icon>
                                            <TextBlock Text="" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                    </StackPanel>
                    
                    <!-- Right: Window Controls -->
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                        <Button Content="" Click="Minimize_Click" Style="{StaticResource ToolbarButtonStyle}" ToolTip="最小化"/>
                        <Button Content="" Click="Close_Click" Style="{StaticResource ToolbarButtonStyle}" Foreground="#FF6B6B" ToolTip="閉じる"/>
                    </StackPanel>

                    <!-- Center: Spacer -->
                    <Grid/>
                </DockPanel>
            </Border>

            <!-- Address Bar & Tools -->
            <Border Grid.Row="1" Background="#252525" Padding="8,4" BorderBrush="#333" BorderThickness="0,1">
                <DockPanel LastChildFill="True">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" Margin="0,0,4,0">
                        <Button Content="" Click="Back_Click" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,4,0" ToolTip="戻る"/>
                        <Button Content="" Click="Forward_Click" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,4,0" ToolTip="進む"/>
                    </StackPanel>
                    
                    <TextBox x:Name="UrlTextBox" Background="#333" Foreground="White" BorderThickness="1" BorderBrush="#444"
                             Padding="8,4" VerticalContentAlignment="Center" KeyDown="UrlTextBox_KeyDown"
                             FontSize="13" SelectionBrush="#0078D4">
                        <TextBox.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                </DockPanel>
            </Border>

            <!-- Bookmark Bar (Horizontal Scroll) -->
            <Border Grid.Row="2" Background="#1E1E1E" BorderBrush="#333" BorderThickness="0,0,0,1">
                <ScrollViewer x:Name="BookmarkScrollViewer" 
                              HorizontalScrollBarVisibility="Hidden" 
                              VerticalScrollBarVisibility="Disabled" 
                              PreviewMouseWheel="BookmarkScrollViewer_PreviewMouseWheel">
                    <ItemsControl x:Name="BookmarkList">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Cursor="Hand" Padding="6" CornerRadius="4" Margin="0,0,2,0"
                                        ToolTip="{Binding Title}"
                                        PreviewMouseLeftButtonDown="Bookmark_PreviewMouseLeftButtonDown" 
                                        MouseMove="Bookmark_MouseMove"
                                        MouseLeftButtonUp="Bookmark_MouseLeftButtonUp"
                                        AllowDrop="True" Drop="Bookmark_Drop" DragOver="Bookmark_DragOver">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#3D3D3D"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="削除" Click="DeleteBookmark_Click"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <Image Source="{Binding DisplayFaviconUrl}" Width="16" Height="16" IsHitTestVisible="False"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- Main Content Area -->
            <Grid Grid.Row="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" x:Name="BrowserSectionRow"/>
                    <RowDefinition Height="Auto" x:Name="MemoSplitterRow"/>
                    <RowDefinition Height="0" x:Name="MemoSectionRow"/>
                </Grid.RowDefinitions>

                <!-- Browser Views Group -->
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" x:Name="TopRow"/>
                        <RowDefinition Height="Auto" x:Name="SplitterRow"/>
                        <RowDefinition Height="0" x:Name="BottomRow"/>
                    </Grid.RowDefinitions>

                    <wv2:WebView2 x:Name="webView" Grid.Row="0" Margin="0" GotFocus="WebView_GotFocus"/>

                    <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" Background="#333" 
                                  Visibility="Collapsed" x:Name="VerticalSplitter" ShowsPreview="True"/>

                    <wv2:WebView2 x:Name="webViewBottom" Grid.Row="2" Margin="0" Visibility="Collapsed" GotFocus="WebView_GotFocus"/>
                </Grid>

                <!-- Memo Splitter (Resizes BrowserSection vs MemoSection) -->
                <GridSplitter x:Name="MemoSplitter" Grid.Row="1" Height="4" HorizontalAlignment="Stretch" Background="#333" 
                              Visibility="Collapsed" ShowsPreview="True" ResizeBehavior="PreviousAndNext"/>

                <!-- Memo Area -->
                <Grid x:Name="MemoArea" Grid.Row="2" Background="#1E1E1E" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Background="#252525" Padding="8,4" BorderBrush="#333" BorderThickness="0,1,0,1">
                        <DockPanel>
                            <TextBlock Text="メモ" VerticalAlignment="Center" Foreground="#AAA" FontSize="11" FontWeight="Bold"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="MemoMaximizeButton" Content="" Style="{StaticResource ToolbarButtonStyle}" 
                                        Width="20" Height="20" FontSize="10" Click="MemoMaximize_Click" ToolTip="最大化"/>
                                <Button Content="" Style="{StaticResource ToolbarButtonStyle}" 
                                        Width="20" Height="20" FontSize="10" Click="Memo_Click" ToolTip="閉じる"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <TextBox x:Name="MemoTextBox" Grid.Row="1" Background="#1E1E1E" Foreground="White" 
                             BorderThickness="0" Padding="8" AcceptsReturn="True" AcceptsTab="True" 
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" TextChanged="MemoTextBox_TextChanged"
                             FontSize="13" FontFamily="Consolas, Meiryo" CaretBrush="White"/>
                </Grid>
            </Grid>
        </Grid>

        <!-- 右側のリサイズグリップ (左側に配置されている時用) -->
        <Border x:Name="RightResizeGrip" Grid.Column="2" Background="Transparent" Cursor="SizeWE" 
                MouseLeftButtonDown="ResizeGrip_MouseDown" MouseMove="ResizeGrip_MouseMove" MouseLeftButtonUp="ResizeGrip_MouseUp"/>

        <!-- リサイズ中のガイド線 -->
        <Rectangle x:Name="ResizePreview" Grid.Column="1" HorizontalAlignment="Left" Width="2" Fill="#0078D4" 
                   Visibility="Collapsed" IsHitTestVisible="False" Opacity="0.8"/>
    </Grid>

</Window>
