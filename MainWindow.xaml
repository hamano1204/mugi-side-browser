<Window x:Class="MugiSideBrowser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="MugiSideBrowser" Height="800" Width="400"
        WindowStyle="None" ResizeMode="NoResize"
        Background="#1E1E1E" FontFamily="Segoe UI Variable Text">
    <Window.Resources>
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3D3D3D"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BookmarkButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Margin" Value="0,0,2,0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar / Toolbar -->
        <Border Grid.Row="0" Background="#2D2D2D" Padding="8,4">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="" Click="Back_Click" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,4,0"/>
                    <Button Content="" Click="Forward_Click" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,4,0"/>
                    <Button Content="" Click="Reload_Click" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,4,0"/>
                    <Button x:Name="SplitButton" Content="" Click="SplitView_Click" Style="{StaticResource ToolbarButtonStyle}" ToolTip="上下分割を切り替え"/>
                </StackPanel>
                
                <Button Content="" DockPanel.Dock="Right" Click="Close_Click" Style="{StaticResource ToolbarButtonStyle}" Foreground="#FF6B6B"/>
                <Button Content="" DockPanel.Dock="Right" Click="Minimize_Click" Style="{StaticResource ToolbarButtonStyle}"/>
                
                <TextBlock Text="MugiSideBrowser" VerticalAlignment="Center" HorizontalAlignment="Center" 
                           Foreground="#E0E0E0" FontWeight="SemiBold" FontSize="12"/>
            </DockPanel>
        </Border>

        <!-- Address Bar -->
        <Border Grid.Row="1" Background="#252525" Padding="8,4" BorderBrush="#333" BorderThickness="0,1">
            <Grid>
                <TextBox x:Name="UrlTextBox" Background="#333" Foreground="White" BorderThickness="1" BorderBrush="#444"
                         Padding="8,4,32,4" VerticalContentAlignment="Center" KeyDown="UrlTextBox_KeyDown"
                         FontSize="13" SelectionBrush="#0078D4">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
                <Button Content="&#xE109;" Click="Star_Click" Style="{StaticResource ToolbarButtonStyle}" 
                        HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="12" Margin="0,0,4,0"/>
            </Grid>
        </Border>

        <!-- Bookmark Bar -->
        <Border Grid.Row="2" Background="#1E1E1E" Padding="4,2" BorderBrush="#333" BorderThickness="0,0,0,1">
            <ItemsControl x:Name="BookmarkList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Cursor="Hand" Padding="6" CornerRadius="4" Margin="0,0,2,0"
                                ToolTip="{Binding Title}"
                                PreviewMouseLeftButtonDown="Bookmark_PreviewMouseLeftButtonDown" 
                                MouseMove="Bookmark_MouseMove"
                                MouseLeftButtonUp="Bookmark_MouseLeftButtonUp"
                                AllowDrop="True" Drop="Bookmark_Drop" DragOver="Bookmark_DragOver">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#3D3D3D"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="削除" Click="DeleteBookmark_Click"/>
                                </ContextMenu>
                            </Border.ContextMenu>
                            <Image Source="{Binding DisplayFaviconUrl}" Width="16" Height="16" IsHitTestVisible="False"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- Browser Area -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" x:Name="TopRow"/>
                <RowDefinition Height="Auto" x:Name="SplitterRow"/>
                <RowDefinition Height="0" x:Name="BottomRow"/>
            </Grid.RowDefinitions>

            <wv2:WebView2 x:Name="webView" Grid.Row="0" Margin="0" GotFocus="WebView_GotFocus"/>

            <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" Background="#333" 
                          Visibility="Collapsed" x:Name="VerticalSplitter" ShowsPreview="True"/>

            <wv2:WebView2 x:Name="webViewBottom" Grid.Row="2" Margin="0" Visibility="Collapsed" GotFocus="WebView_GotFocus"/>
        </Grid>
    </Grid>

</Window>
