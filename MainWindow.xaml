<Window x:Class="MugiSideBrowser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="MugiSideBrowser" Height="800" Width="400" Icon="pack://application:,,,/app_icon.png"
        WindowStyle="None" ResizeMode="NoResize"
        Background="{DynamicResource AppBackground}" FontFamily="Segoe UI Variable Text">
    <Window.Resources>
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="8,0"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SidebarDockButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource SelectionBackground}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HeaderMenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HeaderNavButtonStyle" TargetType="Button" BasedOn="{StaticResource HeaderMenuButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.3"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <ContextMenu x:Key="PageToolsMenu" Opened="PageToolsMenu_Opened">
            <MenuItem Header="ページを更新" Click="Reload_Click">
                <MenuItem.Icon>
                    <TextBlock Text="" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="モバイル表示に切替" Click="UserAgent_Click" Tag="UserAgent">
                <MenuItem.Icon>
                    <TextBlock Text="" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                </MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem Header="このページをブックマーク" Click="Star_Click">
                <MenuItem.Icon>
                    <TextBlock Text="" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="URLをコピー" Click="CopyUrl_Click">
                <MenuItem.Icon>
                    <TextBlock Text="" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="標準ブラウザで開く" Click="OpenExternal_Click">
                <MenuItem.Icon>
                    <TextBlock Text="" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                </MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem Header="初期ページに戻る" Click="ResetToInitialPage_Click" Tag="ResetToInitialPage">
                <MenuItem.Icon>
                    <TextBlock Text="" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="画面を閉じる" Click="CloseActivePane_Click" Tag="CloseActivePane">
                <MenuItem.Icon>
                    <TextBlock Text="" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>
        <!-- タブのアクティブ（青）・オープン（緑）インジケーター色。
             StaticResource として定義（ライトテーマ・ダークテーマ双方で共通のブランドカラーのため）。
             テーマ切替時の動的更新は不要。 -->
        <SolidColorBrush x:Key="TabActiveBar" Color="#4A90E2" />
        <SolidColorBrush x:Key="TabInactiveBar" Color="#2ECC71" />
</Window.Resources>

    <Grid x:Name="RootGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="LeftResizeColumn" Width="4"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="RightResizeColumn" Width="0"/>
        </Grid.ColumnDefinitions>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition x:Name="BottomResizeRow" Height="0"/>
        </Grid.RowDefinitions>

        <!-- 左側のリサイズグリップ (右側に配置されている時用) -->
        <Border x:Name="LeftResizeGrip" Grid.Column="0" Grid.Row="0" Background="Transparent" Cursor="SizeWE" 
                MouseLeftButtonDown="ResizeGrip_MouseDown" MouseMove="ResizeGrip_MouseMove" MouseLeftButtonUp="ResizeGrip_MouseUp"/>
        
        <!-- 下側のリサイズグリップ (自由配置モード用) -->
        <Border x:Name="BottomResizeGrip" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Background="Transparent" Cursor="SizeNS" 
                MouseLeftButtonDown="ResizeGrip_MouseDown" MouseMove="ResizeGrip_MouseMove" MouseLeftButtonUp="ResizeGrip_MouseUp"/>

        <!-- メインコンテンツ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" x:Name="TitleBarRow"/>
                <RowDefinition Height="Auto" x:Name="AddressBarRow"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar / Toolbar -->
            <Border Grid.Row="0" Background="{DynamicResource TitleBarBackground}" Padding="8,4" 
                    MouseLeftButtonDown="TitleBar_MouseDown" 
                    MouseMove="TitleBar_MouseMove" 
                    MouseLeftButtonUp="TitleBar_MouseUp">
                <DockPanel>
                    <!-- Left: Navigation (Empty for clean titlebar) -->
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <TextBlock Text="MugiSideBrowser" Foreground="{DynamicResource SecondaryText}" FontSize="12" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </StackPanel>
                    
                    <!-- Right: Window Controls -->
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                        <Button x:Name="ToggleNormalAppBarButton" Content="&#xE90D;" Click="ToggleNormalAppBar_Click" Style="{StaticResource ToolbarButtonStyle}" ToolTip="サイドバー表示 (AppBar)"/>
                        <Button x:Name="ToggleAppBarAutoHideButton" Content="" Click="ToggleAppBarAutoHide_Click" Style="{StaticResource ToolbarButtonStyle}" ToolTip="自動的に隠す (AutoHide)"/>
                        <Button x:Name="MinimizeButton" Content="" Click="Minimize_Click" Style="{StaticResource ToolbarButtonStyle}" ToolTip="最小化"/>
                        <Button Content="" Click="Close_Click" Style="{StaticResource ToolbarButtonStyle}" Foreground="{DynamicResource DangerForeground}" ToolTip="閉じる"/>
                    </StackPanel>

                    <!-- Center: Spacer -->
                    <Grid/>
                </DockPanel>
            </Border>

            <!-- Address Bar & Tools -->
            <Border Grid.Row="1" Background="{DynamicResource AddressBarBackground}" Padding="8,4" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1">
                <DockPanel LastChildFill="True">
                    

                    <TextBox x:Name="UrlTextBox" Background="{DynamicResource BorderColor}" Foreground="{DynamicResource PrimaryText}" BorderThickness="1" BorderBrush="{DynamicResource TextBoxBorderColor}"
                              Padding="8,4" VerticalContentAlignment="Center" KeyDown="UrlTextBox_KeyDown"
                              FontSize="13" SelectionBrush="{DynamicResource SelectionBackground}">
                        <TextBox.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                </DockPanel>
            </Border>

            <!-- Main Content Area (Dock + Browser Views Group) -->
            <Grid Grid.Row="2" x:Name="MainContentGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" x:Name="SidebarColumn"/>
                    <ColumnDefinition Width="*" x:Name="BrowserColumn"/>
                </Grid.ColumnDefinitions>

                <!-- Vertical Sidebar Dock -->
                <Border x:Name="SidebarBorder" Grid.Column="0" Width="48" Background="{DynamicResource TitleBarBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Top: Add Bookmark Button -->
                            <RowDefinition Height="*"/>    <!-- Center: Bookmarks Scroll List -->
                            <RowDefinition Height="Auto"/> <!-- Bottom: Tools Button -->
                        </Grid.RowDefinitions>

                        <!-- Add Bookmark Button -->
                        <Button Grid.Row="0" Content="" Style="{StaticResource SidebarDockButtonStyle}" 
                                Click="Star_Click" ToolTip="現在のページをブックマーク" Margin="4,6"/>

                        <!-- Bookmark List -->
                        <ScrollViewer Grid.Row="1" x:Name="BookmarkScrollViewer" 
                                      HorizontalScrollBarVisibility="Disabled" 
                                      VerticalScrollBarVisibility="Hidden"
                                      PreviewMouseWheel="BookmarkScrollViewer_PreviewMouseWheel">
                            <ItemsControl x:Name="BookmarkList">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Vertical"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="4"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                             <!-- Color bar -->
                                             <Rectangle x:Name="Bar" Grid.Column="0">
                                                 <Rectangle.Style>
                                                     <Style TargetType="Rectangle">
                                                         <Setter Property="Fill" Value="Transparent"/>
                                                         <Style.Triggers>
                                                             <DataTrigger Binding="{Binding IsOpen}" Value="True">
                                                                 <Setter Property="Fill" Value="{StaticResource TabInactiveBar}"/>
                                                             </DataTrigger>
                                                             <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                 <Setter Property="Fill" Value="{StaticResource TabActiveBar}"/>
                                                             </DataTrigger>
                                                         </Style.Triggers>
                                                     </Style>
                                                 </Rectangle.Style>
                                             </Rectangle>

                                            <!-- Original content -->
                                            <Border x:Name="NormalItemBorder" Grid.Column="1" Cursor="Hand" Padding="8" CornerRadius="6" Margin="4,2"
                                                    ToolTip="{Binding Title}"
                                                    PreviewMouseLeftButtonDown="Bookmark_PreviewMouseLeftButtonDown"
                                                    MouseMove="Bookmark_MouseMove"
                                                    MouseUp="Bookmark_MouseUp"
                                                    AllowDrop="True" Drop="Bookmark_Drop" DragOver="Bookmark_DragOver">
                                                 <Border.Style>
                                                     <Style TargetType="Border">
                                                         <Setter Property="Background" Value="Transparent"/>
                                                         <Setter Property="Opacity" Value="1.0"/>
                                                         <Style.Triggers>
                                                             <Trigger Property="IsMouseOver" Value="True">
                                                                 <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
                                                             </Trigger>
                                                             <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                 <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
                                                                 <Setter Property="Opacity" Value="1.0"/>
                                                             </DataTrigger>
                                                         </Style.Triggers>
                                                     </Style>
                                                 </Border.Style>
                                                 <Border.ContextMenu>
                                                    <ContextMenu Opened="BookmarkContextMenu_Opened">
                                                        <MenuItem Header="分割画面で開く" Click="OpenInSplitScreen_Click"/>
                                                        <Separator/>
                                                        <MenuItem Header="タブを終了" Click="ClearBookmarkState_Click"/>
                                                        <Separator/>
                                                        <MenuItem Header="タブを削除" Click="DeleteBookmark_Click"/>
                                                    </ContextMenu>
                                                </Border.ContextMenu>

                                                <!-- Favicon Image with Scale Transform on Hover for WOW effect -->
                                                <Grid Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Image Source="{Binding DisplayFaviconUrl}" Width="20" Height="20" IsHitTestVisible="False" RenderOptions.BitmapScalingMode="HighQuality">
                                                        <Image.Style>
                                                            <Style TargetType="Image">
                                                                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                                                <Setter Property="RenderTransform">
                                                                    <Setter.Value>
                                                                        <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=IsMouseOver}" Value="True">
                                                                        <DataTrigger.EnterActions>
                                                                            <BeginStoryboard>
                                                                                <Storyboard>
                                                                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)" To="1.15" Duration="0:0:0.15"/>
                                                                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)" To="1.15" Duration="0:0:0.15"/>
                                                                                </Storyboard>
                                                                            </BeginStoryboard>
                                                                        </DataTrigger.EnterActions>
                                                                        <DataTrigger.ExitActions>
                                                                            <BeginStoryboard>
                                                                                <Storyboard>
                                                                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.15"/>
                                                                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.15"/>
                                                                                </Storyboard>
                                                                            </BeginStoryboard>
                                                                        </DataTrigger.ExitActions>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Image.Style>
                                                    </Image>
                                                    <!-- Indicator for memory load status -->
                                                    <Ellipse Width="6" Height="6" Fill="#FF4CAF50" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-2,-2" IsHitTestVisible="False">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsLoaded}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                </Grid>
                                            </Border>

                                            <!-- Separator Element -->
                                            <Border x:Name="SeparatorBorder" Grid.Column="1" Cursor="Hand" Padding="4,4" Margin="4,1" CornerRadius="4" Background="Transparent"
                                                    PreviewMouseLeftButtonDown="Bookmark_PreviewMouseLeftButtonDown" 
                                                    MouseMove="Bookmark_MouseMove"
                                                    MouseLeftButtonUp="Bookmark_MouseLeftButtonUp"
                                                    AllowDrop="True" Drop="Bookmark_Drop" DragOver="Bookmark_DragOver"
                                                    Visibility="Collapsed">
                                                <Border.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="削除" Click="DeleteBookmark_Click"/>
                                                    </ContextMenu>
                                                </Border.ContextMenu>
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Rectangle Height="1" HorizontalAlignment="Stretch" Fill="{DynamicResource BookmarkSeparator}" SnapsToDevicePixels="True"/>
                                            </Border>
                                        </Grid>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsSeparator}" Value="True">
                                                <Setter TargetName="NormalItemBorder" Property="Visibility" Value="Collapsed"/>
                                                <Setter TargetName="SeparatorBorder" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Tools / Settings Button at the bottom -->
                        <Button Grid.Row="2" Content="" Style="{StaticResource SidebarDockButtonStyle}" 
                                Click="Tools_Click" ToolTip="ツールメニュー" Margin="4,6">
                            <Button.ContextMenu>
                                <ContextMenu x:Name="ToolsMenu">
                                    <MenuItem Header="区切り線を追加" Click="AddSeparator_Click">
                                        <MenuItem.Icon>
                                            <TextBlock Text="" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <Separator/>
                                    <MenuItem x:Name="ThemeToggleMenuItem" Header="ライトモードに切り替え" Click="ThemeToggle_Click">
                                        <MenuItem.Icon>
                                            <TextBlock x:Name="ThemeIcon" Text="" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <Separator/>
                                    <MenuItem x:Name="SidebarPositionToggleMenuItem" Header="お気に入りバーを右に配置" Click="SidebarPositionToggle_Click">
                                        <MenuItem.Icon>
                                            <TextBlock x:Name="SidebarPositionIcon" Text="" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <Separator/>
                                    <MenuItem x:Name="ExternalBrowserMenuItem" Header="新しいウィンドウを標準ブラウザで開く" IsCheckable="True" IsChecked="True" Click="ExternalBrowser_Click">
                                        <MenuItem.Icon>
                                            <TextBlock Text="" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                    </Grid>
                </Border>

                <!-- Main Content Area (Browser Views Group) -->
                <Grid x:Name="BrowserGroupGrid" Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" x:Name="TopRow"/>
                        <RowDefinition Height="Auto" x:Name="SplitterRow1"/>
                        <RowDefinition Height="0" x:Name="MiddleRow"/>
                        <RowDefinition Height="Auto" x:Name="SplitterRow2"/>
                        <RowDefinition Height="0" x:Name="BottomRow"/>
                    </Grid.RowDefinitions>

                    <!-- Top Panel -->
                    <Grid x:Name="WebViewContainer" Grid.Row="0" Margin="0" PreviewMouseDown="WebViewContainer_PreviewMouseDown">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Top Header -->
                        <Border x:Name="TopHeader" Grid.Row="0" Height="24" Background="{DynamicResource TitleBarBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1" MouseLeftButtonDown="PaneHeader_MouseDown" Tag="Top" Cursor="Hand" AllowDrop="True" MouseMove="PaneHeader_MouseMove" DragOver="PaneHeader_DragOver" DragLeave="PaneHeader_DragLeave" Drop="PaneHeader_Drop">
                            <DockPanel Margin="8,0">
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                                    <Button x:Name="TopBackButton" Content="&#xE112;" Style="{StaticResource HeaderNavButtonStyle}" Click="HeaderBack_Click" Tag="Top" ToolTip="戻る" Margin="0,0,2,0"/>
                                    <Button x:Name="TopForwardButton" Content="&#xE111;" Style="{StaticResource HeaderNavButtonStyle}" Click="HeaderForward_Click" Tag="Top" ToolTip="進む" Margin="0,0,4,0"/>
                                    <Button x:Name="TopMenuButton" Content="&#xE712;" Style="{StaticResource HeaderMenuButtonStyle}" Click="HeaderPageTools_Click" Tag="Top" ToolTip="ページ操作"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse x:Name="TopActiveIndicator" Width="6" Height="6" Fill="{DynamicResource SelectionBackground}" Margin="0,0,6,0" VerticalAlignment="Center" Visibility="Visible"/>
                                    <TextBlock x:Name="TopHeaderText" Text="メイン画面" FontSize="11" Foreground="{DynamicResource PrimaryText}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <Grid x:Name="WebViewTopHolder" Grid.Row="1"/>
                        
                        <!-- Top Sleep Placeholder -->
                        <Grid x:Name="TopSleepPlaceholder" Grid.Row="1" Visibility="Collapsed" Background="{DynamicResource AppBackground}" MouseLeftButtonDown="TopSleepPlaceholder_Click">
                            <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="12" 
                                    Background="{DynamicResource TitleBarBackground}" Margin="20" Padding="20"
                                     VerticalAlignment="Center" HorizontalAlignment="Stretch" MaxWidth="320">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="48" 
                                               Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                                    <TextBlock x:Name="TopSleepTitle" Text="ページはスリープ状態です" FontWeight="SemiBold" FontSize="16" 
                                               Foreground="{DynamicResource PrimaryText}" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                    <TextBlock Text="メモリを節約するため、バックグラウンドでの動作を一時停止しました。再開ボタンを押すと復帰します。" 
                                               FontSize="12" Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,20"/>
                                    <Button Content="ページを再開する" Click="ResumeTop_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>

                    <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" VerticalAlignment="Center" 
                                  ResizeDirection="Rows" ShowsPreview="False" Background="{DynamicResource BorderColor}" 
                                  Visibility="Collapsed" x:Name="RowSplitter1"/>

                    <!-- Middle Panel -->
                    <Grid x:Name="WebViewMiddleContainer" Grid.Row="2" Margin="0" Visibility="Collapsed" PreviewMouseDown="WebViewMiddleContainer_PreviewMouseDown">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Middle Header -->
                        <Border x:Name="MiddleHeader" Grid.Row="0" Height="24" Background="{DynamicResource TitleBarBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1" MouseLeftButtonDown="PaneHeader_MouseDown" Tag="Middle" Cursor="Hand" AllowDrop="True" MouseMove="PaneHeader_MouseMove" DragOver="PaneHeader_DragOver" DragLeave="PaneHeader_DragLeave" Drop="PaneHeader_Drop">
                            <DockPanel Margin="8,0">
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                                    <Button x:Name="MiddleBackButton" Content="&#xE112;" Style="{StaticResource HeaderNavButtonStyle}" Click="HeaderBack_Click" Tag="Middle" ToolTip="戻る" Margin="0,0,2,0"/>
                                    <Button x:Name="MiddleForwardButton" Content="&#xE111;" Style="{StaticResource HeaderNavButtonStyle}" Click="HeaderForward_Click" Tag="Middle" ToolTip="進む" Margin="0,0,4,0"/>
                                    <Button x:Name="MiddleMenuButton" Content="&#xE712;" Style="{StaticResource HeaderMenuButtonStyle}" Click="HeaderPageTools_Click" Tag="Middle" ToolTip="ページ操作"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse x:Name="MiddleActiveIndicator" Width="6" Height="6" Fill="{DynamicResource SelectionBackground}" Margin="0,0,6,0" VerticalAlignment="Center" Visibility="Collapsed"/>
                                    <TextBlock x:Name="MiddleHeaderText" Text="サブ画面 (中)" FontSize="11" Foreground="{DynamicResource SecondaryText}" FontWeight="Normal" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <Grid x:Name="WebViewMiddleHolder" Grid.Row="1"/>
                        
                        <!-- Middle Sleep Placeholder -->
                        <Grid x:Name="MiddleSleepPlaceholder" Grid.Row="1" Visibility="Collapsed" Background="{DynamicResource AppBackground}" MouseLeftButtonDown="MiddleSleepPlaceholder_Click">
                            <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="12" 
                                    Background="{DynamicResource TitleBarBackground}" Margin="20" Padding="20"
                                    VerticalAlignment="Center" HorizontalAlignment="Stretch" MaxWidth="320">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="48" 
                                               Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                                    <TextBlock x:Name="MiddleSleepTitle" Text="ページはスリープ状態です" FontWeight="SemiBold" FontSize="16" 
                                               Foreground="{DynamicResource PrimaryText}" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                    <TextBlock Text="メモリを節約するため、バックグラウンドでの動作を一時停止しました。再開ボタンを押すと復帰します。" 
                                               FontSize="12" Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,20"/>
                                    <Button Content="ページを再開する" Click="ResumeMiddle_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Middle Empty Placeholder -->
                        <Grid x:Name="MiddleEmptyPlaceholder" Grid.Row="1" Visibility="Visible" Background="{DynamicResource AppBackground}">
                            <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="12" 
                                    Background="{DynamicResource TitleBarBackground}" Margin="20" Padding="20"
                                    VerticalAlignment="Center" HorizontalAlignment="Stretch" MaxWidth="320">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="48" 
                                               Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                                    <TextBlock Text="分割ウィンドウ (中)" FontWeight="SemiBold" FontSize="16" 
                                               Foreground="{DynamicResource PrimaryText}" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBlock Text="お気に入りをここに表示できます。&#x0a;サイドバーのお気に入りを右クリックして「分割画面で開く」を選択してください。" 
                                               FontSize="12" Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>

                    <GridSplitter Grid.Row="3" Height="4" HorizontalAlignment="Stretch" VerticalAlignment="Center" 
                                  ResizeDirection="Rows" ShowsPreview="False" Background="{DynamicResource BorderColor}" 
                                  Visibility="Collapsed" x:Name="RowSplitter2"/>

                    <!-- Bottom Panel -->
                    <!-- Visibility は ApplySplitLayout() でコードから制御するため初期値 Collapsed を明示 -->
                    <Grid x:Name="WebViewBottomContainer" Grid.Row="4" Margin="0" Visibility="Collapsed" PreviewMouseDown="WebViewBottomContainer_PreviewMouseDown">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Bottom Header -->
                        <Border x:Name="BottomHeader" Grid.Row="0" Height="24" Background="{DynamicResource TitleBarBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1" MouseLeftButtonDown="PaneHeader_MouseDown" Tag="Bottom" Cursor="Hand" AllowDrop="True" MouseMove="PaneHeader_MouseMove" DragOver="PaneHeader_DragOver" DragLeave="PaneHeader_DragLeave" Drop="PaneHeader_Drop">
                            <DockPanel Margin="8,0">
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                                    <Button x:Name="BottomBackButton" Content="&#xE112;" Style="{StaticResource HeaderNavButtonStyle}" Click="HeaderBack_Click" Tag="Bottom" ToolTip="戻る" Margin="0,0,2,0"/>
                                    <Button x:Name="BottomForwardButton" Content="&#xE111;" Style="{StaticResource HeaderNavButtonStyle}" Click="HeaderForward_Click" Tag="Bottom" ToolTip="進む" Margin="0,0,4,0"/>
                                    <Button x:Name="BottomMenuButton" Content="&#xE712;" Style="{StaticResource HeaderMenuButtonStyle}" Click="HeaderPageTools_Click" Tag="Bottom" ToolTip="ページ操作"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse x:Name="BottomActiveIndicator" Width="6" Height="6" Fill="{DynamicResource SelectionBackground}" Margin="0,0,6,0" VerticalAlignment="Center" Visibility="Collapsed"/>
                                    <TextBlock x:Name="BottomHeaderText" Text="サブ画面 (下)" FontSize="11" Foreground="{DynamicResource SecondaryText}" FontWeight="Normal" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <Grid x:Name="WebViewBottomHolder" Grid.Row="1"/>
                        
                        <!-- Bottom Sleep Placeholder -->
                        <Grid x:Name="BottomSleepPlaceholder" Grid.Row="1" Visibility="Collapsed" Background="{DynamicResource AppBackground}" MouseLeftButtonDown="BottomSleepPlaceholder_Click">
                            <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="12" 
                                    Background="{DynamicResource TitleBarBackground}" Margin="20" Padding="20"
                                    VerticalAlignment="Center" HorizontalAlignment="Stretch" MaxWidth="320">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="48" 
                                               Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                                    <TextBlock x:Name="BottomSleepTitle" Text="ページはスリープ状態です" FontWeight="SemiBold" FontSize="16" 
                                               Foreground="{DynamicResource PrimaryText}" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                    <TextBlock Text="メモリを節約するため、バックグラウンドでの動作を一時停止しました。再開ボタンを押すと復帰します。" 
                                               FontSize="12" Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,20"/>
                                    <Button Content="ページを再開する" Click="ResumeBottom_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Bottom Empty Placeholder -->
                        <Grid x:Name="BottomEmptyPlaceholder" Grid.Row="1" Visibility="Visible" Background="{DynamicResource AppBackground}">
                            <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="12" 
                                    Background="{DynamicResource TitleBarBackground}" Margin="20" Padding="20"
                                    VerticalAlignment="Center" HorizontalAlignment="Stretch" MaxWidth="320">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="48" 
                                               Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                                    <TextBlock Text="分割ウィンドウ (下)" FontWeight="SemiBold" FontSize="16" 
                                               Foreground="{DynamicResource PrimaryText}" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBlock Text="お気に入りをここに表示できます。&#x0a;サイドバーのお気に入りを右クリックして「分割画面で開く」を選択してください。" 
                                               FontSize="12" Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <!-- 右側のリサイズグリップ (左側に配置されている時用) -->
        <Border x:Name="RightResizeGrip" Grid.Column="2" Background="Transparent" Cursor="SizeWE" 
                MouseLeftButtonDown="ResizeGrip_MouseDown" MouseMove="ResizeGrip_MouseMove" MouseLeftButtonUp="ResizeGrip_MouseUp"/>

        <!-- リサイズ中のガイド線 -->
        <Rectangle x:Name="ResizePreview" Grid.Column="1" HorizontalAlignment="Left" Width="2" Fill="{DynamicResource SelectionBackground}" 
                   Visibility="Collapsed" IsHitTestVisible="False" Opacity="0.8"/>
    </Grid>

</Window>
