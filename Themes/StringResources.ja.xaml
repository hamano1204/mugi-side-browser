<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">
    <!-- Main Window Title & Layout Modes -->
    <system:String x:Key="Title_MainPane">メイン画面</system:String>
    <system:String x:Key="Title_SubPaneMiddle">サブ画面 (中)</system:String>
    <system:String x:Key="Title_SubPaneBottom">サブ画面 (下)</system:String>
    <system:String x:Key="Title_SplitPaneMiddle">分割ウィンドウ (中)</system:String>
    <system:String x:Key="Title_SplitPaneBottom">分割ウィンドウ (下)</system:String>
    
    <system:String x:Key="Mode_AppBar">常時表示</system:String>
    <system:String x:Key="Mode_AutoHide">自動隠し</system:String>
    <system:String x:Key="Mode_Floating">自由配置</system:String>
    <system:String x:Key="Mode_Unknown">不明</system:String>

    <!-- Context Menu Items -->
    <system:String x:Key="Menu_ReloadPage">ページを更新</system:String>
    <system:String x:Key="Menu_SwitchToMobile">モバイル表示に切替</system:String>
    <system:String x:Key="Menu_SwitchToDesktop">デスクトップ表示に切替</system:String>
    <system:String x:Key="Menu_BookmarkThisPage">このページをブックマーク</system:String>
    <system:String x:Key="Menu_CopyUrl">URLをコピー</system:String>
    <system:String x:Key="Menu_OpenInDefaultBrowser">標準ブラウザで開く</system:String>
    <system:String x:Key="Menu_GoToHomePage">初期ページに戻る</system:String>
    <system:String x:Key="Menu_ClosePane">画面を閉じる</system:String>
    <system:String x:Key="Menu_OpenInSplitScreen">分割画面で開く</system:String>
    <system:String x:Key="Menu_CloseTab">タブを終了</system:String>
    <system:String x:Key="Menu_DeleteTab">タブを削除</system:String>
    <system:String x:Key="Menu_Delete">削除</system:String>

    <!-- Tools Menu Items -->
    <system:String x:Key="Menu_AddSeparator">区切り線を追加</system:String>
    <system:String x:Key="Menu_SwitchToLightMode">ライトモードに切り替え</system:String>
    <system:String x:Key="Menu_SwitchToDarkMode">ダークモードに切り替え</system:String>
    <system:String x:Key="Menu_MoveFavoritesLeft">お気に入りバーを左に配置</system:String>
    <system:String x:Key="Menu_MoveFavoritesRight">お気に入りバーを右に配置</system:String>
    <system:String x:Key="Menu_OpenNewWindowInDefaultBrowser">新しいウィンドウを標準ブラウザで開く</system:String>

    <!-- Sleep Placeholders -->
    <system:String x:Key="Sleep_Title">ページはスリープ状態です</system:String>
    <system:String x:Key="Sleep_TitleFormat">「{0}」はスリープ状態です</system:String>
    <system:String x:Key="Sleep_Description">メモリを節約するため、バックグラウンドでの動作を一時停止しました。再開ボタンを押すと復帰します。</system:String>
    <system:String x:Key="Sleep_ResumeButton">ページを再開する</system:String>
    
    <!-- Empty Split Pane Placeholders -->
    <system:String x:Key="Empty_SplitPaneDescription">お気に入りをここに表示できます。&#x0a;サイドバーのお気に入りを右クリックして「分割画面で開く」を選択してください。</system:String>

    <!-- Window Controls & Tooltips -->
    <system:String x:Key="Tooltip_Minimize">最小化</system:String>
    <system:String x:Key="Tooltip_Close">閉じる</system:String>
    <system:String x:Key="Tooltip_BookmarkCurrentPage">現在のページをブックマーク</system:String>
    <system:String x:Key="Tooltip_Back">戻る</system:String>
    <system:String x:Key="Tooltip_Forward">進む</system:String>
    <system:String x:Key="Tooltip_PageTools">ページ操作</system:String>
    <system:String x:Key="Tooltip_ToolsMenu">ツールメニュー</system:String>
    <system:String x:Key="Tooltip_SidebarDisplay">サイドバー表示 (AppBar)</system:String>
    <system:String x:Key="Tooltip_FloatingWindow">自由配置ウィンドウ</system:String>
    <system:String x:Key="Tooltip_AutoHide">自動的に隠す (AutoHide)</system:String>
    <system:String x:Key="Tooltip_AlwaysShow">常時表示 (AppBar)</system:String>

    <!-- Messagebox & Dialog Strings -->
    <system:String x:Key="Msg_FatalError">致命的なエラーが発生しました:&#x0a;&#x0a;{0}&#x0a;&#x0a;{1}</system:String>
    <system:String x:Key="Msg_ErrorTitle">エラー</system:String>
    <system:String x:Key="Msg_AddBookmarkFailed">ブックマークの追加に失敗しました: {0}</system:String>
    <system:String x:Key="Msg_CopyFailed">コピーに失敗しました: {0}</system:String>
    <system:String x:Key="Msg_OpenExternalFailed">標準ブラウザで開けませんでした: {0}</system:String>
    <system:String x:Key="Msg_MoveBookmarkFailed">ブックマークの移動に失敗しました: {0}</system:String>
    <system:String x:Key="Msg_DeleteBookmarkFailed">ブックマークの削除に失敗しました: {0}</system:String>
    <system:String x:Key="Msg_ConfirmDelete">「{0}」を削除しますか？</system:String>
    <system:String x:Key="Msg_ConfirmDeleteTitle">削除の確認</system:String>
    
    <!-- System Tray -->
    <system:String x:Key="Tray_Exit">終了</system:String>
</ResourceDictionary>
