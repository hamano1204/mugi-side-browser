<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ベースカラー -->
    <SolidColorBrush x:Key="AppBackground" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="TitleBarBackground" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="AddressBarBackground" Color="#252525"/>
    
    <!-- 枠線カラー -->
    <SolidColorBrush x:Key="BorderColor" Color="#333333"/>
    <SolidColorBrush x:Key="TextBoxBorderColor" Color="#444444"/>
    
    <!-- テキストカラー -->
    <SolidColorBrush x:Key="PrimaryText" Color="White"/>
    <SolidColorBrush x:Key="SecondaryText" Color="#CCCCCC"/>
    
    <!-- インタラクティブ要素カラー -->
    <SolidColorBrush x:Key="HoverBackground" Color="#3D3D3D"/>
    <SolidColorBrush x:Key="SelectionBackground" Color="#0078D4"/>
    <SolidColorBrush x:Key="DangerForeground" Color="#FF6B6B"/>

</ResourceDictionary>
